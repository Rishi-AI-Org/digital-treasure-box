{
  "buildCommand": "npm run build -w @dtb/web",
  "devCommand": "npm run dev -w @dtb/web",
  "installCommand": "npm install",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/c/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        },
        {
          "key": "Referrer-Policy",
          "value": "no-referrer"
        }
      ]
    }
  ]
}
