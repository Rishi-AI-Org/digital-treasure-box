{
  "manifest_version": 3,
  "name": "DTB21 Clipper",
  "version": "0.1.0",
  "description": "Save links and selected text into your private DTB21 cabinet.",
  "permissions": ["activeTab", "contextMenus", "scripting", "storage"],
  "host_permissions": ["http://localhost:3000/*", "https://*.digitaltreasurebox.app/*"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Save to DTB21",
    "default_popup": "popup.html"
  }
}
